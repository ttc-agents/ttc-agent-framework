{
  "github_org": "ttc-agents",
  "clone_protocol": "ssh",
  "install_root": {
    "mac": "$HOME/AI-Vault",
    "windows": "$env:USERPROFILE\\AI-Vault"
  },
  "prerequisites": {
    "mac": {
      "package_manager": "brew",
      "packages": [
        "git",
        "gh",
        "node",
        "python@3.12",
        "1password-cli"
      ]
    },
    "windows": {
      "package_manager": "winget",
      "packages": [
        "Git.Git",
        "GitHub.cli",
        "OpenJS.NodeJS.LTS",
        "Python.Python.3.12",
        "1Password.CLI"
      ]
    }
  },
  "claude_code": {
    "install_cmd": "npm install -g @anthropic-ai/claude-code"
  },
  "skip_repos": [
    "ttc-agent-framework",
    "ttc-agent-claude-config",
    "ttc-mcp-proton-server",
    "ttc-brand-standards",
    "ttc-agent-oracle-staging"
  ],
  "shared_repos": [
    {
      "repo": "ttc-agent-claude-config",
      "path": "Claude-Config",
      "auto_install": true,
      "note": "User-level Claude config + slash commands. Symlinked from ~/CLAUDE.md and ~/.claude/commands/."
    },
    {
      "repo": "ttc-brand-standards",
      "path": "brand",
      "auto_install": true,
      "note": "TTC standards memos (Excel workbook standard, Claude Design brief spec). Logos/imagery NOT here \u2014 read from OneDrive via Agents/Docs/brand_paths.py."
    },
    {
      "repo": "ttc-mcp-proton-server",
      "path": "Tools/mcp-proton",
      "auto_install": true,
      "note": "MCP server for Proton Mail via local Proton Bridge. Requires 1Password item 'Proton Bridge PWD' in 'AI Vault'. Run npm install after clone."
    },
    {
      "repo": "ttc-agent-oracle-staging",
      "path": "Agents/Oracle",
      "auto_install": false,
      "note": "Parked Oracle agent staging material (oracle-db-skills, apex-component-modifier, utPLSQL). Not used by any active agent."
    }
  ],
  "agents": [
    {
      "repo": "ttc-agent-sap",
      "dir": "SAP",
      "apply": "sap",
      "submodules": true,
      "auto_install": true
    },
    {
      "repo": "ttc-agent-test",
      "dir": "Test",
      "apply": "test",
      "submodules": false,
      "auto_install": true
    },
    {
      "repo": "ttc-agent-taf",
      "dir": "TAF",
      "apply": "taf",
      "submodules": false,
      "auto_install": true
    },
    {
      "repo": "ttc-agent-tender",
      "dir": "Tender",
      "apply": "tender",
      "submodules": false,
      "auto_install": true
    },
    {
      "repo": "ttc-agent-hr",
      "dir": "HR",
      "apply": "hr",
      "submodules": false,
      "auto_install": true
    },
    {
      "repo": "ttc-agent-bwbm",
      "dir": "BwBm",
      "apply": "bwbm",
      "submodules": false,
      "auto_install": false,
      "note": "ARCHIVED 2026-06-01. BwBm migrated to ttc-agent-lead-bwbm (Leads/bwbm/). Repo kept read-only for historical reference. Local dir Agents/BwBm/ contains only MOVED.md."
    },
    {
      "repo": "ttc-agent-docs",
      "dir": "Docs",
      "apply": "docs",
      "submodules": false,
      "auto_install": true
    },
    {
      "repo": "ttc-agent-odoo",
      "dir": "Odoo",
      "apply": "odoo",
      "submodules": false,
      "auto_install": true
    },
    {
      "repo": "ttc-agent-contracts",
      "dir": "Contracts",
      "apply": "contracts",
      "submodules": false,
      "auto_install": true
    },
    {
      "repo": "ttc-agent-finance",
      "dir": "Finance",
      "apply": "finance",
      "submodules": false,
      "auto_install": true
    },
    {
      "repo": "ttc-agent-tom",
      "dir": "QA_TOM_Generator",
      "apply": "tom",
      "submodules": false,
      "auto_install": true
    },
    {
      "repo": "ttc-agent-personal",
      "dir": "Personal",
      "apply": "personal",
      "submodules": false,
      "auto_install": true,
      "note": "Private: owner-only"
    },
    {
      "repo": "ttc-agent-personal-template",
      "dir": "Personal",
      "apply": "personal",
      "submodules": false,
      "auto_install": false,
      "note": "Sanitized template. Conflicts with ttc-agent-personal. Install via: add-agent personal-template"
    },
    {
      "repo": "ttc-agent-private",
      "dir": "Private",
      "apply": "private",
      "submodules": false,
      "auto_install": true
    },
    {
      "repo": "ttc-agent-infra",
      "dir": "Infrastructure",
      "apply": "infra",
      "submodules": false,
      "auto_install": true
    },
    {
      "repo": "ttc-agent-trading",
      "dir": "Trading",
      "apply": "trading",
      "submodules": false,
      "auto_install": true
    },
    {
      "repo": "ttc-agent-trading-hf",
      "dir": "Trading-HF",
      "apply": "trading-hf",
      "submodules": false,
      "auto_install": true
    },
    {
      "repo": "ttc-agent-trading-ibkr",
      "dir": "Trading-IBKR",
      "apply": "trading-ibkr",
      "submodules": false,
      "auto_install": true
    },
    {
      "repo": "ttc-agent-control-review",
      "dir": "Control-Review",
      "apply": "control-review",
      "submodules": false,
      "auto_install": true
    },
    {
      "repo": "ttc-agent-curator",
      "dir": "Curator",
      "apply": "curator",
      "submodules": false,
      "auto_install": true
    },
    {
      "repo": "ttc-agent-sales-admin",
      "dir": "Sales-Admin",
      "apply": "sales-admin",
      "submodules": false,
      "auto_install": false,
      "note": "Joerg's master Sales agent. Contains live customer-identifier watchlist + send-mail gate. Not auto-installed on team machines; clone manually on Joerg's machines only."
    },
    {
      "repo": "ttc-agent-sales",
      "dir": "Sales",
      "apply": "sales",
      "submodules": false,
      "auto_install": true,
      "note": "TTC team read-only Sales agent. Queries OneDrive Network KB snapshot. Safe to install on any team member's machine."
    },
    {
      "repo": null,
      "dir": "OpenDesk",
      "apply": "opendesk",
      "submodules": false,
      "auto_install": false,
      "note": "Local-only agent (no GitHub repo). Joerg's OpenDesk/Nextcloud integration helper. Not distributed — no source control, must be kept manually in sync across machines."
    },
    {
      "repo": null,
      "dir": "AutoLead",
      "apply": "autolead",
      "submodules": false,
      "auto_install": false,
      "note": "Local git repo (no GitHub remote yet). Orchestrates TAF test lifecycle; dispatches subagents test-designer/taf-author/taf-healer/triage. Not yet distributed — promote to ttc-agents org when subagent schema stabilises."
    },
    {
      "repo": null,
      "dir": "Leads/_generic",
      "apply": "customer",
      "submodules": false,
      "auto_install": true,
      "note": "Generic lead template — deployed from ttc-agent-framework/leads/_generic/ by install.sh/update-all.sh. Handles long-tail customers via 'apply customer <slug>'."
    },
    {
      "repo": null,
      "dir": "AppDev",
      "apply": "appdev",
      "submodules": false,
      "auto_install": false,
      "note": "PRIVATE/non-TTC. Local git repo, no GitHub remote. CardBenefits UAE app orchestrator (5 stack-aligned subagents). Deliberately excluded from ttc-agents distribution. Detail: Agents/Infrastructure/memory/appdev-agent.md"
    },
    {
      "repo": "ttc-agent-lead-bwbm",
      "dir": "Leads/bwbm",
      "apply": "bwbm",
      "submodules": false,
      "auto_install": true
    },
    {
      "repo": "ttc-agent-lead-vkb",
      "dir": "Leads/vkb",
      "apply": "vkb",
      "submodules": false,
      "auto_install": true
    },
    {
      "repo": "ttc-agent-lead-dubai-holding",
      "dir": "Leads/dubai-holding",
      "apply": "dubai-holding",
      "submodules": false,
      "auto_install": true
    },
    {
      "repo": "ttc-agent-lead-cbuae",
      "dir": "Leads/cbuae",
      "apply": "cbuae",
      "submodules": false,
      "auto_install": true
    },
    {
      "repo": "ttc-agent-lead-qatar-energy",
      "dir": "Leads/qatar-energy",
      "apply": "qatar-energy",
      "submodules": false,
      "auto_install": true
    },
    {
      "repo": "ttc-agent-lead-dib",
      "dir": "Leads/dib",
      "apply": "dib",
      "submodules": false,
      "auto_install": true
    }
  ],
  "_excluded_agents_note": {
    "AppDev": "Deliberately excluded from ttc-agents distribution. PRIVATE/non-TTC agent for the CardBenefits UAE app. Local git repo, no GitHub remote. Orchestrates 5 stack-aligned subagents (data/backend/ios/qa/infra). Detail: Agents/Infrastructure/memory/appdev-agent.md"
  }
}
